# Copy this file to .env and fill in your keys.
# NEVER commit your real .env to GitHub.

# Required: Anthropic API key (powers the summaries)
# Get one at https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Required for email delivery: Resend API key
# Get one at https://resend.com -> API Keys (free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model (defaults to a fast, cheap model)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
